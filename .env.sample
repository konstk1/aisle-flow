# Neon Postgres connection string from the Vercel Neon integration.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/aisle_flow?sslmode=require

# Better Auth signing secret, at least 32 characters.
BETTER_AUTH_SECRET=replace-with-a-random-secret-of-at-least-32-characters

# Public base URL for auth callbacks, for example http://localhost:3000 locally.
BETTER_AUTH_URL=replace-with-app-base-url

# Google OAuth app credentials.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Comma-separated Google account emails allowed to sign in.
ALLOWED_EMAILS=kon.klitenik@gmail.com

# Fine-grained GitHub token with Issues: write for konstk1/aisle-flow only.
GITHUB_ISSUES_TOKEN=replace-with-a-server-only-github-token
