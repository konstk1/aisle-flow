# Neon Postgres connection string from the Vercel Neon integration.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/aisle_flow?sslmode=require

# Better Auth signing secret, at least 32 characters. Must be identical across
# every deployment (production and preview) so the OAuth proxy can decrypt the
# sign-in payload it forwards between them.
BETTER_AUTH_SECRET=replace-with-a-random-secret-of-at-least-32-characters

# The production base URL Google's OAuth callback is registered against
# (http://localhost:3000 locally). Set this to the SAME production URL in both
# the Vercel Production and Preview environments — preview deployments serve
# from their own per-build URL (VERCEL_URL) and proxy the OAuth handshake
# through this production URL.
BETTER_AUTH_URL=replace-with-app-base-url

# Google OAuth app credentials.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Comma-separated Google account emails allowed to sign in.
ALLOWED_EMAILS=kon.klitenik@gmail.com

# LOCAL DEVELOPMENT ONLY. Set to "true" to expose GET /api/auth/dev-login, which
# signs in as an allowlisted account without Google OAuth so preview browsers
# that can't complete the redirect can still reach the app. Ignored on every
# deployment (also guarded by NODE_ENV and VERCEL); never set this in Vercel.
# ENABLE_DEV_LOGIN=true

# Fine-grained GitHub token with Issues: write for konstk1/aisle-flow only.
GITHUB_ISSUES_TOKEN=replace-with-a-server-only-github-token
